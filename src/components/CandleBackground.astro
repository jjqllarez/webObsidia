---
// src/components/CandleBackground.astro
---

<canvas
  id="candle-canvas"
  class="fixed top-0 left-0 -z-10 w-full h-full bg-[#010101]"></canvas>

<script>
  const canvas = document.getElementById("candle-canvas");
  const ctx = canvas?.getContext("2d");

  // ========== DETECTAR DISPOSITIVO MÓVIL ==========
  const isMobile =
    /Mobi|Android|iPhone|iPad|iPod/i.test(navigator.userAgent) ||
    window.innerWidth < 768;
  console.log("Modo móvil activado:", isMobile);

  // ========== PARÁMETROS CONFIGURABLES (se ajustan automáticamente en móvil) ==========
  const BASE_CONFIG = {
    BACKGROUND_IMAGE_ENABLED: true,
    BACKGROUND_IMAGE_PATH: `${import.meta.env.BASE_URL}/fondo.png`,
    BACKGROUND_IMAGE_OPACITY: 0.1,
    MIN_RADIUS: 25,
    MAX_RADIUS: 50,
    SPEED_FACTOR: isMobile ? 1.2 : 2,
    COLLISION_ITERATIONS: isMobile ? 1 : 3,
    BUBBLE_OPACITY: 0.3,
    BUBBLE_FILL_COLOR: "rgba(20, 20, 30, 0.8)",
    BUBBLE_STROKE_COLOR: "rgba(255, 255, 255, 0.1)",
    SHADOW_BLUR: isMobile ? 0 : 15,
    SHADOW_COLOR: "rgba(120, 50, 255, 0.3)",
    ICON_SIZE_FACTOR: 1.2,
    TEXT_CONFIG: {
      offsetY: 0.95,
      fontSizeFactor: 0.4,
      fontWeight: "bold",
      colorPositive: "#81c784",
      colorNegative: "#e57373",
      colorLoading: "#aaaaaa",
    },
    PRICE_UPDATE_INTERVAL: 3600000,
    COINGECKO_API_URL: "https://api.coingecko.com/api/v3/simple/price",
    BUBBLE_COUNT: isMobile ? 8 : 20,
  };

  // ========== TU LISTA ORIGINAL DE CRYPTO ICONOS ==========
  const cryptoIcons = [
    {
      name: "BTC",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/btc.png",
    },
    {
      name: "ETH",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/eth.png",
    },
    {
      name: "SOL",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/sol.png",
    },
    {
      name: "XRP",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/xrp.png",
    },
    {
      name: "ADA",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/ada.png",
    },
    {
      name: "BNB",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/bnb.png",
    },
    {
      name: "DOT",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/dot.png",
    },
    {
      name: "LTC",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/ltc.png",
    },
    {
      name: "USDT",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/usdt.png",
    },
    {
      name: "USDC",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/usdc.png",
    },
    {
      name: "DAI",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/dai.png",
    },
    {
      name: "MATIC",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/matic.png",
    },
    {
      name: "DOGE",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/doge.png",
    },
    {
      name: "AVAX",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/avax.png",
    },
    {
      name: "TRX",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/trx.png",
    },
    {
      name: "UNI",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/uni.png",
    },
    {
      name: "LINK",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/link.png",
    },
    {
      name: "ATOM",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/atom.png",
    },
    {
      name: "XLM",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/xlm.png",
    },
    {
      name: "VET",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/vet.png",
    },
    {
      name: "FIL",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/fil.png",
    },
    {
      name: "ALGO",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/algo.png",
    },
    {
      name: "ETC",
      url: "https://raw.githubusercontent.com/spothq/cryptocurrency-icons/master/128/color/etc.png",
    },
  ];

  const stablecoins = new Set(["USDT", "USDC", "DAI", "BUSD"]);
  let validImages = [];

  const coinGeckoIds = {
    BTC: "bitcoin",
    ETH: "ethereum",
    SOL: "solana",
    XRP: "ripple",
    ADA: "cardano",
    BNB: "binancecoin",
    DOT: "polkadot",
    LTC: "litecoin",
    USDT: "tether",
    USDC: "usd-coin",
    DAI: "dai",
    BUSD: "binance-usd",
    MATIC: "matic-network",
    DOGE: "dogecoin",
    SHIB: "shiba-inu",
    AVAX: "avalanche-2",
    TRX: "tron",
    UNI: "uniswap",
    LINK: "chainlink",
    ATOM: "cosmos",
    XLM: "stellar",
    VET: "vechain",
    FIL: "filecoin",
    ALGO: "algorand",
    ETC: "ethereum-classic",
  };

  let priceData = {};
  cryptoIcons.forEach((icon) => {
    priceData[icon.name] = {
      change24h: null,
      loading: true,
      error: false,
    };
  });

  let w, h;
  let bubbles = [];
  let backgroundImage = null;
  if (BASE_CONFIG.BACKGROUND_IMAGE_ENABLED) {
    backgroundImage = new Image();
    backgroundImage.src = BASE_CONFIG.BACKGROUND_IMAGE_PATH;
  }

  // ========== LIMITAR FRAMERATE EN MÓVIL (30 fps) ==========
  let lastFrameTime = 0;
  const TARGET_FPS = isMobile ? 30 : 60;
  const FRAME_INTERVAL = 1000 / TARGET_FPS;

  async function loadImages() {
    const promises = cryptoIcons.map((icon) => {
      return new Promise((resolve) => {
        const img = new Image();
        img.src = icon.url;
        img.onload = () => resolve(img);
        img.onerror = () => resolve(null);
      });
    });
    const results = await Promise.all(promises);
    validImages = results.filter((img) => img !== null);
    console.log(
      `Imágenes válidas: ${validImages.length} de ${cryptoIcons.length}`,
    );
    init();
  }

  function shuffleArray(array) {
    for (let i = array.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [array[i], array[j]] = [array[j], array[i]];
    }
    return array;
  }

  function init() {
    if (!canvas || !ctx) return;
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
    bubbles = [];

    const availableCount = Math.min(
      BASE_CONFIG.BUBBLE_COUNT,
      validImages.length,
    );
    if (availableCount === 0) {
      console.error("No hay imágenes válidas para mostrar");
      return;
    }

    const shuffled = shuffleArray([...validImages]);
    const selectedImages = shuffled.slice(0, availableCount);

    for (let i = 0; i < availableCount; i++) {
      const radius =
        Math.random() * (BASE_CONFIG.MAX_RADIUS - BASE_CONFIG.MIN_RADIUS) +
        BASE_CONFIG.MIN_RADIUS;
      const imgSrc = selectedImages[i].src;
      const iconEntry = cryptoIcons.find((icon) => icon.url === imgSrc);
      const coinName = iconEntry ? iconEntry.name : "UNKNOWN";
      bubbles.push({
        x: Math.random() * (w - radius * 2) + radius,
        y: Math.random() * (h - radius * 2) + radius,
        radius: radius,
        vx: (Math.random() - 0.5) * BASE_CONFIG.SPEED_FACTOR,
        vy: (Math.random() - 0.5) * BASE_CONFIG.SPEED_FACTOR,
        img: selectedImages[i],
        coinName: coinName,
        opacity: BASE_CONFIG.BUBBLE_OPACITY,
      });
    }
    fetchPriceChanges();
  }

  async function fetchPriceChanges() {
    try {
      const activeCoins = bubbles.map((b) => b.coinName);
      const uniqueCoins = [...new Set(activeCoins)];
      const coinsToFetch = uniqueCoins.filter(
        (name) => coinGeckoIds[name] && !stablecoins.has(name),
      );
      if (coinsToFetch.length === 0) return;
      const ids = coinsToFetch.map((name) => coinGeckoIds[name]).join(",");
      const url = `${BASE_CONFIG.COINGECKO_API_URL}?ids=${ids}&vs_currencies=usd&include_24hr_change=true`;
      const response = await fetch(url);
      if (!response.ok)
        throw new Error(`HTTP error! status: ${response.status}`);
      const data = await response.json();
      coinsToFetch.forEach((coinName) => {
        const geckoId = coinGeckoIds[coinName];
        if (data[geckoId] && data[geckoId].usd_24h_change !== undefined) {
          priceData[coinName] = {
            change24h: data[geckoId].usd_24h_change,
            loading: false,
            error: false,
          };
        } else {
          priceData[coinName] = {
            ...priceData[coinName],
            loading: false,
            error: true,
          };
        }
      });
      stablecoins.forEach((coin) => {
        if (priceData[coin]) priceData[coin].loading = false;
      });
      console.log("Precios actualizados:", new Date().toLocaleTimeString());
    } catch (error) {
      console.error("Error fetching price data:", error);
      bubbles.forEach((b) => {
        if (!stablecoins.has(b.coinName) && priceData[b.coinName]) {
          priceData[b.coinName].loading = false;
          priceData[b.coinName].error = true;
        }
      });
    }
  }

  function handleBubbleCollisions() {
    if (BASE_CONFIG.COLLISION_ITERATIONS === 0) return;
    for (let iter = 0; iter < BASE_CONFIG.COLLISION_ITERATIONS; iter++) {
      for (let i = 0; i < bubbles.length; i++) {
        for (let j = i + 1; j < bubbles.length; j++) {
          const b1 = bubbles[i];
          const b2 = bubbles[j];
          const dx = b2.x - b1.x;
          const dy = b2.y - b1.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const minDist = b1.radius + b2.radius;
          if (dist < minDist) {
            const m1 = b1.radius * b1.radius;
            const m2 = b2.radius * b2.radius;
            const totalMass = m1 + m2;
            const nx = dx / dist;
            const ny = dy / dist;
            const vx = b2.vx - b1.vx;
            const vy = b2.vy - b1.vy;
            const velAlong = vx * nx + vy * ny;
            if (velAlong > 0) continue;
            const impulse = (2 * velAlong) / totalMass;
            b1.vx += impulse * m2 * nx;
            b1.vy += impulse * m2 * ny;
            b2.vx -= impulse * m1 * nx;
            b2.vy -= impulse * m1 * ny;
            const overlap = minDist - dist;
            const correction = overlap / 2;
            b1.x -= nx * correction;
            b1.y -= ny * correction;
            b2.x += nx * correction;
            b2.y += ny * correction;
          }
        }
      }
    }
  }

  function draw(now) {
    if (isMobile) {
      if (now - lastFrameTime < FRAME_INTERVAL) {
        requestAnimationFrame(draw);
        return;
      }
      lastFrameTime = now;
    }

    if (!ctx) return;

    ctx.clearRect(0, 0, w, h);
    if (
      BASE_CONFIG.BACKGROUND_IMAGE_ENABLED &&
      backgroundImage &&
      backgroundImage.complete
    ) {
      ctx.globalAlpha = BASE_CONFIG.BACKGROUND_IMAGE_OPACITY;
      ctx.drawImage(backgroundImage, 0, 0, w, h);
      ctx.globalAlpha = 1;
    } else {
      ctx.fillStyle = "#010101";
      ctx.fillRect(0, 0, w, h);
    }

    for (let b of bubbles) {
      b.x += b.vx;
      b.y += b.vy;
    }
    handleBubbleCollisions();

    for (let b of bubbles) {
      if (b.x + b.radius > w) {
        b.x = w - b.radius;
        b.vx *= -1;
      } else if (b.x - b.radius < 0) {
        b.x = b.radius;
        b.vx *= -1;
      }
      if (b.y + b.radius > h) {
        b.y = h - b.radius;
        b.vy *= -1;
      } else if (b.y - b.radius < 0) {
        b.y = b.radius;
        b.vy *= -1;
      }
    }

    // Configuración global (sombra, trazo) – el relleno se asignará dentro del bucle
    ctx.shadowBlur = BASE_CONFIG.SHADOW_BLUR;
    ctx.shadowColor = BASE_CONFIG.SHADOW_COLOR;
    ctx.strokeStyle = BASE_CONFIG.BUBBLE_STROKE_COLOR;

    for (let b of bubbles) {
      ctx.beginPath();
      ctx.arc(b.x, b.y, b.radius, 0, Math.PI * 2);

      // ✅ Forzar el color de la burbuja justo antes de rellenar
      ctx.fillStyle = BASE_CONFIG.BUBBLE_FILL_COLOR;
      ctx.globalAlpha = b.opacity;
      ctx.fill();
      ctx.stroke();

      // Logo
      if (b.img.complete) {
        const iconSize = b.radius * BASE_CONFIG.ICON_SIZE_FACTOR;
        ctx.drawImage(
          b.img,
          b.x - iconSize / 2,
          b.y - iconSize / 2,
          iconSize,
          iconSize,
        );
      }

      // Texto de porcentaje (solo si no es stablecoin)
      if (!stablecoins.has(b.coinName)) {
        const coinPrice = priceData[b.coinName];
        let displayText = null;
        let textColor = BASE_CONFIG.TEXT_CONFIG.colorLoading;
        if (coinPrice) {
          if (coinPrice.loading) displayText = "...";
          else if (!coinPrice.error && coinPrice.change24h !== null) {
            const change = coinPrice.change24h;
            displayText = `${change > 0 ? "+" : ""}${change.toFixed(2)}%`;
            textColor =
              change >= 0
                ? BASE_CONFIG.TEXT_CONFIG.colorPositive
                : BASE_CONFIG.TEXT_CONFIG.colorNegative;
          }
        }
        if (displayText) {
          const fontSize = b.radius * BASE_CONFIG.TEXT_CONFIG.fontSizeFactor;
          ctx.font = `${BASE_CONFIG.TEXT_CONFIG.fontWeight} ${fontSize}px 'Inter', 'Segoe UI', sans-serif`;
          ctx.textAlign = "center";
          ctx.textBaseline = "middle";
          if (!isMobile) {
            ctx.shadowBlur = 2;
            ctx.shadowColor = "rgba(0,0,0,0.5)";
          } else {
            ctx.shadowBlur = 0;
          }
          ctx.fillStyle = textColor;
          const textY = b.y + b.radius * BASE_CONFIG.TEXT_CONFIG.offsetY;
          ctx.fillText(displayText, b.x, textY);
        }
      }
    }

    // Restaurar sombra y alpha para el siguiente frame
    ctx.shadowBlur = 0;
    ctx.globalAlpha = 1;
    requestAnimationFrame(draw);
  }

  loadImages();
  window.addEventListener("resize", () => init());
  setInterval(fetchPriceChanges, BASE_CONFIG.PRICE_UPDATE_INTERVAL);
  window.addEventListener("focus", fetchPriceChanges);
  requestAnimationFrame(draw);
</script>
