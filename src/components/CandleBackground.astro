---
// src/components/CandleBackground.astro
import { getImage } from "astro:assets";
import backgroundAsset from "../assets/fondo.png";

// Prop para controlar la opacidad (valor entre 0 y 1)
export interface Props {
  bgOpacity?: number;
}

const { bgOpacity = 0.1 } = Astro.props;

// Optimizamos la imagen en el servidor
const optimizedDesktop = await getImage({
  src: backgroundAsset,
  format: "webp",
  width: 1920,
  quality: 80,
});

const optimizedMobile = await getImage({
  src: backgroundAsset,
  format: "webp",
  width: 800,
  quality: 60,
});
---

<div class="fixed top-0 left-0 -z-10 w-full h-full bg-[#010101]">
  <picture class="block w-full h-full">
    <source
      media="(max-width: 1023px)"
      srcset={optimizedMobile.src}
      type="image/webp"
    />
    <source
      media="(min-width: 1024px)"
      srcset={optimizedDesktop.src}
      type="image/webp"
    />
    <img
      src={optimizedDesktop.src}
      alt="Background"
      class="w-full h-full object-cover"
      style={`opacity: ${bgOpacity};`}
      loading="eager"
    />
  </picture>
</div>
