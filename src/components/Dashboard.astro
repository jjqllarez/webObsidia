---
// Sin lógica en el frontmatter
---

<section class="dashboard-wrapper" client:load>
  <div class="glass-card">
    <div class="dashboard-header">
      <div class="status-group">
        <div class="dot" id="status-dot"></div>
        <span class="title">LIVE TERMINAL / ALGORITHMIC METRICS</span>
      </div>
      <div class="api-status">
        Status: <span id="api-status-text" class="text-green"
          >Connecting...</span
        >
      </div>
    </div>

    <div class="metrics-grid">
      <div class="stat-box">
        <label>Total Profit (P&L)</label>
        <div class="value" id="profit">+$0</div>
        <span class="sub">Snapshot Data</span>
      </div>

      <div class="stat-box">
        <label>Win Rate</label>
        <div class="value" id="winrate">0%</div>
        <span class="sub">Above Average</span>
      </div>

      <div class="stat-box">
        <label>Drawdown Max.</label>
        <div class="value text-red" id="drawdown">0%</div>
        <span class="sub">Low Risk Profile</span>
      </div>

      <div class="stat-box">
        <label>Active Orders</label>
        <div class="value" id="activeOrders">0</div>
        <span class="sub">Live Positions</span>
      </div>
    </div>
  </div>
</section>

<script>
  import { createClient } from "@supabase/supabase-js";

  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  if (!supabaseUrl || !supabaseAnonKey) {
    console.error("❌ Supabase credentials missing");
    const statusSpan = document.getElementById("api-status-text");
    if (statusSpan) statusSpan.innerText = "Missing credentials";
    // No usar return, simplemente no continuar
  } else {
    const supabase = createClient(supabaseUrl, supabaseAnonKey);

    async function fetchMetrics() {
      try {
        const { data: stats, error } = await supabase
          .from("trading_metrics")
          .select("*")
          .order("created_at", { ascending: false })
          .limit(1)
          .single();

        if (error) throw error;

        const currentStats = stats || {
          total_profit: 0,
          win_rate: 0,
          drawdown: 0,
          active_orders: 0,
          bot_status: "offline",
        };

        const profitEl = document.getElementById("profit");
        if (profitEl)
          profitEl.innerHTML = `+$${Number(currentStats.total_profit).toLocaleString()}`;

        const winrateEl = document.getElementById("winrate");
        if (winrateEl) winrateEl.innerText = `${currentStats.win_rate}%`;

        const drawdownEl = document.getElementById("drawdown");
        if (drawdownEl) drawdownEl.innerText = `${currentStats.drawdown}%`;

        const activeOrdersEl = document.getElementById("activeOrders");
        if (activeOrdersEl)
          activeOrdersEl.innerText = currentStats.active_orders;

        const statusDot = document.getElementById("status-dot");
        const statusText = document.getElementById("api-status-text");

        if (currentStats.bot_status === "active") {
          if (statusDot) statusDot.className = "dot bg-green";
          if (statusText) {
            statusText.innerHTML = "Connected to WEEX API";
            statusText.className = "text-green";
          }
        } else {
          if (statusDot) statusDot.className = "dot bg-orange";
          if (statusText) {
            statusText.innerHTML = "Bot Offline";
            statusText.className = "text-red";
          }
        }
      } catch (err) {
        console.error("Error fetching metrics:", err);
        const statusText = document.getElementById("api-status-text");
        if (statusText) {
          statusText.innerText = "Error loading data";
          statusText.className = "text-red";
        }
      }
    }

    fetchMetrics();
    setInterval(fetchMetrics, 30000);
  }
</script>

<style>
  .dashboard-wrapper {
    position: relative;
    z-index: 10;
    padding: 2rem;
    max-width: 1100px;
    margin: -50px auto 0;
  }

  .glass-card {
    background: rgba(10, 10, 10, 0.8);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .dashboard-header {
    display: flex;
    justify-content: space-between;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    padding-bottom: 1rem;
    margin-bottom: 1.5rem;
  }

  .status-group {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .bg-green {
    background: #22c55e;
    box-shadow: 0 0 10px #22c55e;
  }

  .bg-orange {
    background: #f59e0b;
  }

  .title {
    font-size: 0.7rem;
    letter-spacing: 2px;
    color: rgba(255, 255, 255, 0.6);
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .stat-box label {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.5);
    display: block;
  }

  .value {
    font-size: 1.8rem;
    font-weight: bold;
    margin: 5px 0;
  }

  .sub {
    font-size: 0.65rem;
    font-style: italic;
    opacity: 0.5;
  }

  .text-green {
    color: #22c55e;
  }

  .text-red {
    color: #ef4444;
  }
</style>
